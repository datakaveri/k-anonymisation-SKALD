{
  "data_type": "test",
  "test": {
    "pass": "pass2",
    "output_path": "generalized_test.csv",
    "output_directory": "output",
    "suppression_limit": 0.05,

    "suppress": ["Customer ID", "Full Name", "Street Address"],
    "hashing_with_salt": ["Aadhaar", "PAN ID", "Bank Account Number"],
    "hashing_without_salt": [],
    "masking": [],
    "encrypt": ["Email", "Phone", "IFSC Code", "UPI ID"],
    "charcloak": [],
    "tokenization": [],
    "fpe": [],

    "quasi_identifiers": {
      "categorical": [{ "column": "Blood Group" }],
      "numerical": [
        { "column": "Age",      "encode": false, "type": "int" },
        { "column": "PIN Code", "encode": false, "type": "int" }
      ]
    },

    "qi_constraints": {
      "Age": {
        "intervals": [
          {"from": 22, "to": 30},
          {"from": 31, "to": 45},
          {"from": 46, "to": 60},
          {"from": 61, "to": 75}
        ]
      },
      "PIN Code": {
        "intervals": [
          {"from": 110000, "to": 300000},
          {"from": 300001, "to": 500000},
          {"from": 500001, "to": 700000},
          {"from": 700001, "to": 797001}
        ]
      }
    },

    "size": { "Age": 2, "PIN Code": 10 },

    "k_anonymize": { "k": 50 }
  }
}
