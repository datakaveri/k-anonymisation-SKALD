{
  "operations": [
    "SKALD",
    "k-anonymity",
    "suppress",
    "hash",
    "mask",
    "tokenization",
    "fpe",
    "encrypt"
  ],
  "data_type": "BeneficiaryData",
  "BeneficiaryData": {
    "output_path": "generalized_beneficiary.csv",
    "output_directory": "output",
    "log_file": "log.txt",

    "insensitive_columns": [
      "SLNO",
      "MEMEBERSLNO",
      "URN",
      "MEMBERID",
      "FULLNAMEENGLISH",
      "AADHARNUMBER",
      "GENDER",
      "DATEOFBIRTH",
      "AGE",
      "RELATIONWITHFAMILYHEAD",
      "STATENAME",
      "STATECODE",
      "DISTRICTNAME",
      "DISTRICTCODE",
      "BLOCKNAME",
      "BLOCKCODE",
      "PANCHAYAT_TOWNNAME",
      "PANCHAYAT_TOWNCODE",
      "VILLAGENAME",
      "VILLAGECODE",
      "HEAD_MEMBERID",
      "HEAD_MEMBERNAME",
      "MORTALITY_STATUS",
      "SCHEMEID",
      "SCHEMECATEGORYID",
      "EXPORTDATE",
      "CREATEDON",
      "UPDATEDON",
      "STATUSFLAG",
      "UIDREFERENCENUMBER",
      "SCHEMETYPE",
      "EKYC_STATUS",
      "PAN"
    ],

    "suppress": [
      "UIDREFERENCENUMBER"
    ],

    "hashing_with_salt": [
      "AADHARNUMBER"
    ],

    "hashing_without_salt": [
      "URN"
    ],

    "masking": [
      {
        "column": "DATEOFBIRTH",
        "masking_char": "*",
        "characters_to_mask": [1, 2, 5, 7, 9],
        "regex_patterns": [
          {
            "type": "before",
            "delimiter": "-",
            "regex": "^.+?(?=-)"
          }
        ]
      },
      {
        "column": "SCHEMECATEGORYID",
        "masking_char": "*",
        "regex_patterns": [
          {
            "type": "after",
            "delimiter": "/",
            "regex": "(?<=/).+$"
          }
        ]
      },
      {
        "column": "SCHEMEID",
        "masking_char": "*",
        "characters_to_mask": [],
        "regex_patterns": [
          {
            "type": "in_between",
            "start": " ",
            "end": "$",
            "regex": "(?<=\\s).+$"
          }
        ]
      }
    ],

    "tokenization": [
      {
        "column": "MEMBERID",
        "prefix": "TK-",
        "digits": 8
      }
    ],



    "encrypt": [
      {
        "FULLNAMEENGLISH": {
          "format_preserving": true
        }
      }
    ],

    "charcloak": [
      "HEAD_MEMBERNAME"
    ],


    "quasi_identifiers": {
      "categorical": [],
      "numerical": [
        {
          "column": "AGE",
          "encode": false,
          "scale": false,
          "type": "int"
        },
        {
          "column": "DISTRICTCODE",
          "encode": false,
          "scale": false,
          "type": "int"
        }
      ]
    },

    "size": {
      "AGE": 2,
      "DISTRICTCODE": 2
    },

    "k_anonymize": {
      "k": 2
    },

    "enable_l_diversity": false,
    "suppression_limit": 0.06
  }
}
